@model DeffChildAccount

@{
    ViewData["Title"] = "Child Account Details";
}

<div class="page-header">
    <h2><i class="bi bi-eye"></i> Child Account Details</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-light py-2">
                <strong>Account INFO</strong>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Account Code</dt>
                    <dd class="col-sm-8"><strong>@Model.AccountCode</strong></dd>

                    <dt class="col-sm-4">Account Name</dt>
                    <dd class="col-sm-8">@Model.AccountName</dd>

                    <dt class="col-sm-4">Parent Account</dt>
                    <dd class="col-sm-8">
                        @if (Model.ParentAccount != null)
                        {
                            <a asp-action="Details" asp-route-id="@Model.ParentAccount.Id">
                                @Model.ParentAccount.AccountCode - @Model.ParentAccount.AccountName
                            </a>
                        }
                        else
                        {
                            <span class="badge bg-info">Root</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Cost Center</dt>
                    <dd class="col-sm-8">
                        @if (Model.CostCenter != null)
                        {
                            <span class="badge bg-primary">@Model.CostCenter.CostCenterCode</span>
                            <span class="ms-2 fw-semibold">@Model.CostCenter.CostCenterName</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.Active)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>
                    }

                    <dt class="col-sm-4">Created Date</dt>
                    <dd class="col-sm-8">@Model.CreatedDate.ToString("yyyy-MM-dd")</dd>
                </dl>
            </div>
        </div>
    </div>

    @if (Model.Children.Any())
    {
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-light py-2">
                    <strong>Child Accounts (@Model.Children.Count)</strong>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var child in Model.Children)
                        {
                            <li class="list-group-item py-2">
                                <a asp-action="Details" asp-route-id="@child.Id">
                                    @child.AccountCode - @child.AccountName
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    }
</div>
