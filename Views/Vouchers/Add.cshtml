@model Concept.Models.VoucherHeader

@{
    ViewData["Title"] = "Add Voucher";
}

<div class="page-header">
    <h2><i class="bi bi-plus-circle"></i> Add New Voucher</h2>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Add" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="VoucherNo" class="form-label">Voucher No <span class="text-danger">*</span></label>
                            <input asp-for="VoucherNo" class="form-control" readonly />
                            <span asp-validation-for="VoucherNo" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherDate" class="form-label">Voucher Date <span class="text-danger">*</span></label>
                            <input asp-for="VoucherDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="VoucherDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="VoucherType" class="form-label">Voucher Type <span class="text-danger">*</span></label>
                        <select asp-for="VoucherType" class="form-select">
                            <option value="">-- Select Type --</option>
                            <option value="Receipt">Receipt</option>
                            <option value="Payment">Payment</option>
                            <option value="Journal">Journal</option>
                        </select>
                        <span asp-validation-for="VoucherType" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Voucher description..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="TotalDebit" class="form-label">Total Debit</label>
                            <input asp-for="TotalDebit" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="TotalDebit" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TotalCredit" class="form-label">Total Credit</label>
                            <input asp-for="TotalCredit" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="TotalCredit" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UserId" class="form-label">User ID <span class="text-danger">*</span></label>
                        <input asp-for="UserId" type="number" class="form-control" />
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Save
                        </button>
                        <a href="/Vouchers" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
