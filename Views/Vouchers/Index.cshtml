@model IEnumerable<Concept.Models.VoucherHeader>

@{
    ViewData["Title"] = "Vouchers";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2><i class="bi bi-receipt"></i> Vouchers Management</h2>
    <a href="/Vouchers/Add" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Voucher
    </a>
</div>

<div class="table-responsive mt-3">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Voucher No</th>
                <th>Date</th>
                <th>Type</th>
                <th>Description</th>
                <th class="text-end">Total Debit</th>
                <th class="text-end">Total Credit</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var voucher in Model)
            {
                <tr>
                    <td><strong>@voucher.VoucherNo</strong></td>
                    <td>@voucher.VoucherDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        @{
                            var typeClass = voucher.VoucherType switch
                            {
                                "Receipt" => "bg-success",
                                "Payment" => "bg-danger",
                                _ => "bg-info"
                            };
                        }
                        <span class="badge @typeClass">@voucher.VoucherType</span>
                    </td>
                    <td>@voucher.Description</td>
                    <td class="text-end">@voucher.TotalDebit.ToString("N2")</td>
                    <td class="text-end">@voucher.TotalCredit.ToString("N2")</td>
                    <td>
                        @if (voucher.Status == 0)
                        {
                            <span class="badge bg-warning text-dark">Draft</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Posted</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-2">
                            <a href="/Vouchers/Delete/@voucher.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-4">
        <i class="bi bi-info-circle"></i> No vouchers found. Click "Add New Voucher" to create one.
    </div>
}
