@* Shared layout for all 3 definition pages — rendered via partial *@
@model dynamic

<style>
    .def-page { background:white; min-height:calc(100vh - 70px); padding:12px; }
    .def-title { color:#8b0000; font-weight:bold; font-size:1.05rem; margin-bottom:10px; }

    .def-layout { display:flex; gap:12px; height:calc(100vh - 130px); }

    /* List panel */
    .def-list-panel {
        width:340px; background:white; border:1px solid #ccc;
        display:flex; flex-direction:column; flex-shrink:0;
    }
    .def-list-header {
        background:#8b0000; color:white; padding:5px 10px;
        font-size:0.8rem; font-weight:bold;
    }
    .def-list-body { flex:1; overflow-y:auto; }
    table.def-table { width:100%; border-collapse:collapse; font-size:0.8rem; }
    table.def-table thead tr { background:#f5f5f5; }
    table.def-table th, table.def-table td { padding:5px 8px; border-bottom:1px solid #eee; text-align:left; }
    table.def-table tbody tr { cursor:pointer; }
    table.def-table tbody tr:hover { background:#e8f0fe; }
    table.def-table tbody tr.selected { background:#cce0ff; font-weight:bold; }
    .inactive-row { color:#aaa; }

    /* Form panel */
    .def-form-panel {
        flex:1; background:white; border:1px solid #ccc; padding:14px 18px;
    }
    .def-form-title { font-size:0.82rem; font-weight:600; color:#333; margin-bottom:12px;
        border-bottom:1px solid #ddd; padding-bottom:5px; }
    .frow { display:flex; align-items:center; margin-bottom:10px; gap:8px; font-size:0.8rem; }
    .frow label { min-width:80px; text-align:right; color:#444; flex-shrink:0; }
    .frow input[type="text"] { width:200px; border:1px solid #999; padding:3px 6px; font-size:0.8rem; }
    .frow input[type="text"].ro { background:#e8e8e8; font-weight:bold; }
    .alert-banner { padding:5px 12px; font-size:0.8rem; border-radius:3px; margin-bottom:8px; display:none; }
    .alert-success { background:#d4edda; color:#155724; border:1px solid #c3e6cb; }
    .alert-danger  { background:#f8d7da; color:#721c24; border:1px solid #f5c6cb; }
</style>
