@{
    ViewData["Title"] = "Cash Transaction";
}

<style>
    .ct-page {
        background: #fff;
        min-height: calc(100vh - 70px);
        padding: 10px 14px;
        font-size: 0.82rem;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .page-title {
        color: #8b0000;
        font-weight: bold;
        font-size: 1.1rem;
        margin-bottom: 8px;
    }

    /* Top bar */
    .top-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 8px;
        flex-wrap: wrap;
    }

    .radio-group {
        display: flex;
        gap: 16px;
        border: 1px solid #bbb;
        padding: 3px 10px;
        background: #f5f5f5;
    }

    .radio-group label {
        display: flex;
        align-items: center;
        gap: 4px;
        cursor: pointer;
        white-space: nowrap;
    }

    .search-bar {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-left: auto;
    }

    .search-bar label {
        white-space: nowrap;
    }

    .search-bar input[type="text"] {
        width: 160px;
        border: 1px solid #999;
        padding: 2px 5px;
        font-size: 0.82rem;
        height: 24px;
    }

    .ct-btn {
        padding: 2px 14px;
        font-size: 0.82rem;
        background: #e0e0e0;
        border: 1px solid #999;
        cursor: pointer;
        height: 24px;
        white-space: nowrap;
    }

    .ct-btn:hover { background: #ccc; }
    .ct-btn-primary { background: #d4edda; border-color: #28a745; color: #155724; font-weight: bold; }
    .ct-btn-primary:hover { background: #c3e6cb; }
    .ct-btn-danger { background: #f8d7da; border-color: #dc3545; color: #721c24; }
    .ct-btn-danger:hover { background: #f5c6cb; }

    /* Form section */
    .form-section {
        border: 1px solid #bbb;
        padding: 8px 12px;
        margin-bottom: 8px;
        background: #fff;
    }

    .form-section legend {
        font-size: 0.8rem;
        padding: 0 4px;
        color: #333;
        width: auto;
        font-weight: normal;
    }

    .form-grid {
        display: grid;
        grid-template-columns: auto 160px auto 160px;
        gap: 5px 10px;
        align-items: center;
    }

    .form-grid label {
        white-space: nowrap;
        text-align: right;
    }

    .form-grid input[type="text"],
    .form-grid input[type="number"],
    .form-grid input[type="date"],
    .form-grid select {
        border: 1px solid #999;
        padding: 2px 5px;
        font-size: 0.82rem;
        height: 24px;
        width: 100%;
    }

    .form-grid textarea {
        border: 1px solid #999;
        padding: 3px 5px;
        font-size: 0.82rem;
        width: 100%;
        resize: none;
        height: 52px;
    }

    .span-full { grid-column: 1 / -1; }
    .span-3 { grid-column: span 3; }

    /* Account info row */
    .acct-info-wrap {
        display: flex;
        gap: 4px;
        align-items: center;
    }

    .acct-info-wrap input {
        flex: 1;
    }

    /* Grid section */
    .grid-section {
        border: 1px solid #bbb;
        margin-bottom: 6px;
    }

    .grid-section-header {
        background: #ddd;
        padding: 3px 8px;
        font-size: 0.8rem;
        font-weight: bold;
        border-bottom: 1px solid #bbb;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .grid-wrapper {
        overflow: auto;
        max-height: 280px;
        background: #fff;
    }

    .ct-grid {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.8rem;
        min-width: 700px;
    }

    .ct-grid thead th {
        background: #ddd;
        border: 1px solid #bbb;
        padding: 3px 6px;
        text-align: center;
        font-weight: normal;
        white-space: nowrap;
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .ct-grid tbody td {
        border: 1px solid #ccc;
        padding: 0;
    }

    .ct-grid tbody tr.selected-row td { background: #cce5ff; }
    .ct-grid tbody tr:hover td { background: #eef; }
    .ct-grid tbody tr.selected-row:hover td { background: #b8d9ff; }

    .row-indicator {
        width: 20px;
        text-align: center;
        font-size: 0.9rem;
        color: #555;
        background: #e8e8e8;
        border-right: 1px solid #bbb;
        padding: 2px;
    }

    .grid-cell-input {
        width: 100%;
        border: none;
        outline: none;
        padding: 2px 4px;
        font-size: 0.8rem;
        background: transparent;
        height: 22px;
        box-sizing: border-box;
    }

    .grid-cell-input:focus { background: #fffbe6; outline: 1px solid #f90; }

    .grid-cell-readonly {
        padding: 2px 4px;
        height: 22px;
        display: block;
        overflow: hidden;
        white-space: nowrap;
    }

    /* Bottom bar */
    .bottom-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        padding: 4px 0;
    }

    /* Alert */
    .alert-banner {
        padding: 4px 10px;
        font-size: 0.82rem;
        border-radius: 3px;
        margin-bottom: 5px;
        display: none;
    }

    .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .alert-danger  { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }

    /* Account Tree Popup */
    .popup-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: rgba(0,0,0,0.35);
        z-index: 9000;
    }

    .popup-box {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        background: #fff;
        border: 1px solid #999;
        width: 640px;
        max-height: 480px;
        display: flex;
        flex-direction: column;
        box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    }

    .popup-box.sm { width: 420px; }

    .popup-header {
        background: #8b0000;
        color: #fff;
        padding: 5px 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
        font-weight: bold;
    }

    .popup-header button {
        background: none;
        border: none;
        color: #fff;
        font-size: 1rem;
        cursor: pointer;
        padding: 0;
    }

    .popup-search {
        display: flex;
        gap: 6px;
        padding: 6px 8px;
        border-bottom: 1px solid #ddd;
    }

    .popup-search input {
        flex: 1;
        border: 1px solid #999;
        padding: 2px 5px;
        font-size: 0.82rem;
        height: 24px;
    }

    .popup-table-wrap { flex: 1; overflow: auto; }

    .popup-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.8rem;
    }

    .popup-table thead th {
        background: #e0e0e0;
        border: 1px solid #bbb;
        padding: 3px 6px;
        text-align: left;
        position: sticky;
        top: 0;
    }

    .popup-table tbody tr { cursor: pointer; }
    .popup-table tbody tr:hover td { background: #cce5ff; }
    .popup-table tbody td { border: 1px solid #ddd; padding: 2px 6px; }

    .no-data { color: #888; text-align: center; padding: 10px; }
</style>

<div class="ct-page">
    <div class="page-title">CashTransaction</div>

    <div id="alertBanner" class="alert-banner"></div>

    <!-- Top bar: type toggle + search -->
    <div class="top-bar">
        <div class="radio-group">
            <label>
                <input type="radio" name="transactionType" id="radioCashWithDraw" value="CashWithDraw" checked onchange="onTypeChange()" />
                Cash With Draw
            </label>
            <label>
                <input type="radio" name="transactionType" id="radioCashReceive" value="CashReceive" onchange="onTypeChange()" />
                Cash Receive
            </label>
        </div>

        <div class="search-bar">
            <label>Search For Invoice No.</label>
            <input type="text" id="searchInvoiceNo" placeholder="" />
            <button class="ct-btn" onclick="searchTransaction()">Search</button>
            <button class="ct-btn ct-btn-primary" onclick="newTransaction()">New</button>
        </div>
    </div>

    <!-- Header form -->
    <fieldset class="form-section">
        <legend id="formLegend">Cash With Draw</legend>
        <div class="form-grid">
            <!-- Row 1 -->
            <label>Invoice No.</label>
            <input type="text" id="invoiceNo" readonly style="background:#f5f5f5;" />

            <label>Cash Name</label>
            <input type="text" id="cashName" />

            <!-- Row 2 -->
            <label>Account Info</label>
            <div class="acct-info-wrap" style="grid-column: span 3;">
                <input type="text" id="accountInfo" style="width:200px;" />
            </div>

            <!-- Row 3 -->
            <label>Pay To</label>
            <select id="payTo" onchange="onPayToChange()">
                <option value="Insurance companies">Insurance companies</option>
                <option value="Suppliers" selected>Suppliers</option>
                <option value="Account Tree">Account Tree</option>
                <option value="Patient">Patient</option>
            </select>

            <label>Discount</label>
            <input type="number" id="discount" value="0" min="0" step="0.01" onchange="calcAmountAfterDiscount()" />

            <!-- Row 4 -->
            <label>Amount</label>
            <input type="number" id="amount" value="0" min="0" step="0.01" onchange="calcAmountAfterDiscount()" />

            <label>Amount After Disc.</label>
            <input type="number" id="amountAfterDiscount" value="0" min="0" step="0.01" readonly style="background:#f5f5f5;" />

            <!-- Row 5 -->
            <label>Payment method</label>
            <select id="paymentMethod">
                <option value="Cash">Cash</option>
                <option value="Bank Transfer">Bank Transfer</option>
                <option value="Cheque">Cheque</option>
            </select>

            <label>Date</label>
            <input type="date" id="transactionDate" />

            <!-- Row 6: Note -->
            <label>Note</label>
            <textarea id="note" style="grid-column: span 3;"></textarea>
        </div>
    </fieldset>

    <!-- Detail grid -->
    <div class="grid-section">
        <div class="grid-section-header">
            <span id="gridTitle">Details</span>
            <button class="ct-btn" id="btnAddFromTree" onclick="openAccountTreePopup()" style="display:none;">
                + Add Account
            </button>
            <button class="ct-btn" id="btnAddSupplier" onclick="openSupplierPopup()" style="display:none;">
                + Add Supplier
            </button>
        </div>
        <div class="grid-wrapper">
            <table class="ct-grid" id="ctGrid">
                <thead id="ctGridHead">
                    <!-- filled dynamically -->
                </thead>
                <tbody id="ctGridBody">
                    <!-- rows filled dynamically -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- Bottom action bar -->
    <div class="bottom-bar">
        <button class="ct-btn ct-btn-danger" onclick="deleteSelectedRow()">Delete Row</button>
        <button class="ct-btn ct-btn-primary" onclick="saveTransaction()" style="padding: 2px 24px;">Save</button>
        <button class="ct-btn ct-btn-danger" onclick="deleteTransaction()">Delete</button>
    </div>
</div>

<!-- Account Tree Popup -->
<div class="popup-overlay" id="acctTreePopup">
    <div class="popup-box">
        <div class="popup-header">
            <span>Select Account</span>
            <button onclick="closeAcctTreePopup()">&times;</button>
        </div>
        <div class="popup-search">
            <input type="text" id="acctTreeSearch" placeholder="Account No or Name..." onkeyup="searchAcctTree()" />
            <button class="ct-btn" onclick="searchAcctTree()">Search</button>
        </div>
        <div class="popup-table-wrap">
            <table class="popup-table">
                <thead>
                    <tr>
                        <th>Account No</th>
                        <th>Account Name</th>
                        <th>Parent Account</th>
                        <th>Nature</th>
                    </tr>
                </thead>
                <tbody id="acctTreeBody"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Supplier Popup -->
<div class="popup-overlay" id="supplierPopup">
    <div class="popup-box sm">
        <div class="popup-header">
            <span>Select Supplier</span>
            <button onclick="closeSupplierPopup()">&times;</button>
        </div>
        <div class="popup-search">
            <input type="text" id="supplierSearch" placeholder="Code or Name..." onkeyup="searchSuppliers()" />
            <button class="ct-btn" onclick="searchSuppliers()">Search</button>
        </div>
        <div class="popup-table-wrap">
            <table class="popup-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                    </tr>
                </thead>
                <tbody id="supplierBody"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── State ─────────────────────────────────────────────────────────────
        let currentId = 0;
        let selectedRowIndex = -1;
        let rows = [];

        // ── Init ──────────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', async function () {
            const today = new Date();
            document.getElementById('transactionDate').value = today.toISOString().split('T')[0];
            await loadNextInvoiceNo();
            applyPayToLayout();
            addEmptyRow();
        });

        async function loadNextInvoiceNo() {
            const type = document.querySelector('input[name="transactionType"]:checked').value;
            const res = await fetch(`/CashTransaction/GetNextInvoiceNo?type=${encodeURIComponent(type)}`);
            const data = await res.json();
            document.getElementById('invoiceNo').value = data.invoiceNo;
        }

        async function onTypeChange() {
            const type = document.querySelector('input[name="transactionType"]:checked').value;
            document.getElementById('formLegend').textContent = type === 'CashWithDraw' ? 'Cash With Draw' : 'Cash Receive';
            await loadNextInvoiceNo();
        }

        // ── Pay To layout ─────────────────────────────────────────────────────
        function onPayToChange() {
            rows = [];
            selectedRowIndex = -1;
            applyPayToLayout();
            addEmptyRow();
        }

        function applyPayToLayout() {
            const payTo = document.getElementById('payTo').value;
            const btnTree     = document.getElementById('btnAddFromTree');
            const btnSupplier = document.getElementById('btnAddSupplier');
            btnTree.style.display     = (payTo === 'Account Tree') ? '' : 'none';
            btnSupplier.style.display = (payTo === 'Suppliers')    ? '' : 'none';

            const head = document.getElementById('ctGridHead');
            if (payTo === 'Account Tree') {
                document.getElementById('gridTitle').textContent = 'Account Tree Lines';
                head.innerHTML = `<tr>
                    <th style="width:20px;"></th>
                    <th style="width:120px;">Account No</th>
                    <th style="min-width:200px;">Account Name</th>
                    <th style="width:110px;">Amount</th>
                    <th style="min-width:140px;">Note</th>
                </tr>`;
            } else {
                const label = payTo === 'Insurance companies' ? 'Insurance Company'
                            : payTo === 'Patient'             ? 'Patient Name'
                            : 'Supplier Name';
                document.getElementById('gridTitle').textContent = payTo + ' Lines';
                head.innerHTML = `<tr>
                    <th style="width:20px;"></th>
                    <th style="min-width:160px;">${esc(label)}</th>
                    <th style="width:130px;">Invoice No</th>
                    <th style="width:120px;">Received Date</th>
                    <th style="width:110px;">Amount</th>
                    <th style="min-width:120px;">Note</th>
                </tr>`;
            }
        }

        // ── Rows ──────────────────────────────────────────────────────────────
        function addEmptyRow() {
            rows.push({ entityId: 0, entityCode: '', entityName: '', invoiceNo: '', receivedDate: '', amount: 0, note: '' });
            renderGrid();
        }

        function renderGrid() {
            const payTo = document.getElementById('payTo').value;
            const tbody = document.getElementById('ctGridBody');
            tbody.innerHTML = '';

            rows.forEach((row, i) => {
                const tr = document.createElement('tr');
                if (i === selectedRowIndex) tr.classList.add('selected-row');
                tr.onclick = () => selectRow(i);

                let cells = '';
                const indicator = i === rows.length - 1 ? '*' : (i + 1);

                if (payTo === 'Account Tree') {
                    cells = `
                        <td class="row-indicator">${indicator}</td>
                        <td style="width:120px;">
                            <input type="text" class="grid-cell-input" value="${esc(row.entityCode)}"
                                data-row="${i}" readonly
                                ondblclick="openAccountTreePopup(${i})"
                                onfocus="selectRow(${i})"
                                title="Double-click to select account" style="cursor:pointer;" />
                        </td>
                        <td>
                            <span class="grid-cell-readonly">${esc(row.entityName)}</span>
                        </td>
                        <td style="width:110px;">
                            <input type="number" class="grid-cell-input" value="${row.amount || ''}" min="0" step="0.01"
                                onchange="rows[${i}].amount = parseFloat(this.value)||0; checkAddRow(${i});" onfocus="selectRow(${i})" />
                        </td>
                        <td>
                            <input type="text" class="grid-cell-input" value="${esc(row.note)}"
                                onchange="rows[${i}].note = this.value; checkAddRow(${i});" onfocus="selectRow(${i})" />
                        </td>`;
                } else {
                    cells = `
                        <td class="row-indicator">${indicator}</td>
                        <td>
                            <input type="text" class="grid-cell-input" value="${esc(row.entityName)}"
                                data-row="${i}"
                                onchange="rows[${i}].entityName = this.value; checkAddRow(${i});"
                                onfocus="selectRow(${i})" />
                        </td>
                        <td style="width:130px;">
                            <input type="text" class="grid-cell-input" value="${esc(row.invoiceNo)}"
                                onchange="rows[${i}].invoiceNo = this.value; checkAddRow(${i});" onfocus="selectRow(${i})" />
                        </td>
                        <td style="width:120px;">
                            <input type="date" class="grid-cell-input" value="${esc(row.receivedDate)}"
                                onchange="rows[${i}].receivedDate = this.value; checkAddRow(${i});" onfocus="selectRow(${i})" />
                        </td>
                        <td style="width:110px;">
                            <input type="number" class="grid-cell-input" value="${row.amount || ''}" min="0" step="0.01"
                                onchange="rows[${i}].amount = parseFloat(this.value)||0; checkAddRow(${i});" onfocus="selectRow(${i})" />
                        </td>
                        <td>
                            <input type="text" class="grid-cell-input" value="${esc(row.note)}"
                                onchange="rows[${i}].note = this.value; checkAddRow(${i});" onfocus="selectRow(${i})" />
                        </td>`;
                }

                tr.innerHTML = cells;
                tbody.appendChild(tr);
            });
        }

        function selectRow(i) {
            selectedRowIndex = i;
            document.querySelectorAll('#ctGridBody tr').forEach((tr, idx) => {
                tr.classList.toggle('selected-row', idx === i);
            });
        }

        function checkAddRow(i) {
            const row = rows[i];
            const payTo = document.getElementById('payTo').value;
            const hasData = payTo === 'Account Tree'
                ? (row.entityCode.trim() !== '')
                : (row.entityName.trim() !== '' || row.invoiceNo.trim() !== '');
            if (i === rows.length - 1 && hasData) addEmptyRow();
        }

        function deleteSelectedRow() {
            if (selectedRowIndex < 0 || rows.length <= 1) return;
            rows.splice(selectedRowIndex, 1);
            selectedRowIndex = Math.min(selectedRowIndex, rows.length - 1);
            renderGrid();
        }

        // ── Calc ──────────────────────────────────────────────────────────────
        function calcAmountAfterDiscount() {
            const amount   = parseFloat(document.getElementById('amount').value) || 0;
            const discount = parseFloat(document.getElementById('discount').value) || 0;
            document.getElementById('amountAfterDiscount').value = Math.max(0, amount - discount).toFixed(2);
        }

        // ── Account Tree Popup ────────────────────────────────────────────────
        let acctTargetRow = -1;
        let acctSearchTimer;

        function openAccountTreePopup(rowIndex) {
            acctTargetRow = (rowIndex !== undefined) ? rowIndex : (rows.length - 1);
            document.getElementById('acctTreeSearch').value = '';
            document.getElementById('acctTreeBody').innerHTML = '';
            document.getElementById('acctTreePopup').style.display = 'block';
            document.getElementById('acctTreeSearch').focus();
            searchAcctTree();
        }

        function closeAcctTreePopup() {
            document.getElementById('acctTreePopup').style.display = 'none';
        }

        function searchAcctTree() {
            clearTimeout(acctSearchTimer);
            acctSearchTimer = setTimeout(async () => {
                const term = document.getElementById('acctTreeSearch').value;
                const res = await fetch(`/CashTransaction/SearchAccounts?term=${encodeURIComponent(term)}`);
                const list = await res.json();
                const tbody = document.getElementById('acctTreeBody');
                tbody.innerHTML = '';
                if (list.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="no-data">No accounts found.</td></tr>';
                    return;
                }
                list.forEach(a => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `<td>${esc(a.accountNo)}</td><td>${esc(a.accountName)}</td><td>${esc(a.parentName)}</td><td>${esc(a.natureOfAccount)}</td>`;
                    tr.onclick = () => selectAccountFromTree(a);
                    tbody.appendChild(tr);
                });
            }, 250);
        }

        function selectAccountFromTree(a) {
            const i = acctTargetRow >= 0 ? acctTargetRow : rows.length - 1;
            rows[i].entityId   = a.id;
            rows[i].entityCode = a.accountNo;
            rows[i].entityName = a.accountName;
            checkAddRow(i);
            closeAcctTreePopup();
            renderGrid();
        }

        // ── Supplier Popup ────────────────────────────────────────────────────
        let supplierSearchTimer;

        function openSupplierPopup() {
            document.getElementById('supplierSearch').value = '';
            document.getElementById('supplierBody').innerHTML = '';
            document.getElementById('supplierPopup').style.display = 'block';
            document.getElementById('supplierSearch').focus();
            searchSuppliers();
        }

        function closeSupplierPopup() {
            document.getElementById('supplierPopup').style.display = 'none';
        }

        function searchSuppliers() {
            clearTimeout(supplierSearchTimer);
            supplierSearchTimer = setTimeout(async () => {
                const term = document.getElementById('supplierSearch').value;
                const res = await fetch(`/CashTransaction/GetSuppliers?term=${encodeURIComponent(term)}`);
                const list = await res.json();
                const tbody = document.getElementById('supplierBody');
                tbody.innerHTML = '';
                if (list.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="2" class="no-data">No suppliers found.</td></tr>';
                    return;
                }
                list.forEach(s => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `<td>${esc(s.code)}</td><td>${esc(s.name)}</td>`;
                    tr.onclick = () => selectSupplier(s);
                    tbody.appendChild(tr);
                });
            }, 250);
        }

        function selectSupplier(s) {
            const i = rows.length - 1;
            rows[i].entityId   = s.id;
            rows[i].entityCode = s.code;
            rows[i].entityName = s.name;
            checkAddRow(i);
            closeSupplierPopup();
            renderGrid();
        }

        // ── New / Search ──────────────────────────────────────────────────────
        async function newTransaction() {
            currentId = 0;
            selectedRowIndex = -1;
            await loadNextInvoiceNo();

            const today = new Date();
            document.getElementById('transactionDate').value = today.toISOString().split('T')[0];
            document.getElementById('cashName').value = '';
            document.getElementById('accountInfo').value = '';
            document.getElementById('payTo').value = 'Suppliers';
            document.getElementById('discount').value = '0';
            document.getElementById('amount').value = '0';
            document.getElementById('amountAfterDiscount').value = '0';
            document.getElementById('paymentMethod').value = 'Cash';
            document.getElementById('note').value = '';
            document.getElementById('searchInvoiceNo').value = '';

            rows = [];
            applyPayToLayout();
            addEmptyRow();
        }

        async function searchTransaction() {
            const no = document.getElementById('searchInvoiceNo').value.trim();
            if (!no) { showAlert('Please enter an Invoice No to search.', false); return; }

            const res = await fetch(`/CashTransaction/GetTransaction?invoiceNo=${encodeURIComponent(no)}`);
            const data = await res.json();
            if (!data.success) { showAlert(data.message, false); return; }

            loadTransactionData(data);
            showAlert('Loaded successfully.', true);
        }

        function loadTransactionData(data) {
            currentId = data.id;
            document.getElementById('invoiceNo').value = data.invoiceNo;

            if (data.transactionType === 'CashReceive') {
                document.getElementById('radioCashReceive').checked = true;
            } else {
                document.getElementById('radioCashWithDraw').checked = true;
            }
            document.getElementById('formLegend').textContent = data.transactionType === 'CashReceive' ? 'Cash Receive' : 'Cash With Draw';

            document.getElementById('cashName').value = data.cashName;
            document.getElementById('accountInfo').value = data.accountInfo;
            document.getElementById('payTo').value = data.payTo;
            document.getElementById('discount').value = data.discount;
            document.getElementById('amountAfterDiscount').value = data.amountAfterDiscount;
            document.getElementById('paymentMethod').value = data.paymentMethod;
            document.getElementById('transactionDate').value = data.transactionDate;
            document.getElementById('note').value = data.note;

            rows = data.details.map(d => ({
                entityId: d.entityId || 0,
                entityCode: d.entityCode || '',
                entityName: d.entityName || '',
                invoiceNo: d.invoiceNo || '',
                receivedDate: d.receivedDate || '',
                amount: d.amount || 0,
                note: d.note || ''
            }));
            rows.push({ entityId: 0, entityCode: '', entityName: '', invoiceNo: '', receivedDate: '', amount: 0, note: '' });
            selectedRowIndex = -1;

            applyPayToLayout();
            renderGrid();
        }

        // ── Save / Delete ─────────────────────────────────────────────────────
        async function saveTransaction() {
            const dataRows = rows.filter(r => {
                const payTo = document.getElementById('payTo').value;
                return payTo === 'Account Tree' ? r.entityCode.trim() !== '' : (r.entityName.trim() !== '' || r.invoiceNo.trim() !== '');
            });

            const payload = {
                id: currentId,
                invoiceNo: document.getElementById('invoiceNo').value,
                transactionType: document.querySelector('input[name="transactionType"]:checked').value,
                cashName: document.getElementById('cashName').value,
                accountInfo: document.getElementById('accountInfo').value,
                payTo: document.getElementById('payTo').value,
                discount: parseFloat(document.getElementById('discount').value) || 0,
                amountAfterDiscount: parseFloat(document.getElementById('amountAfterDiscount').value) || 0,
                paymentMethod: document.getElementById('paymentMethod').value,
                transactionDate: document.getElementById('transactionDate').value,
                note: document.getElementById('note').value,
                details: dataRows.map(r => ({
                    entityName: r.entityName,
                    entityCode: r.entityCode,
                    entityId: r.entityId,
                    invoiceNo: r.invoiceNo,
                    receivedDate: r.receivedDate || null,
                    amount: parseFloat(r.amount) || 0,
                    note: r.note
                }))
            };

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            const res = await fetch('/CashTransaction/Save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(payload)
            });

            const result = await res.json();
            if (result.success) {
                currentId = result.id;
                showAlert(result.message, true);
                if (payload.id === 0) {
                    await newTransaction();
                }
            } else {
                showAlert(result.message, false);
            }
        }

        async function deleteTransaction() {
            if (currentId === 0) { showAlert('No record loaded to delete.', false); return; }
            if (!confirm('Delete this transaction?')) return;

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            const res = await fetch('/CashTransaction/Delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
                body: `id=${currentId}`
            });
            const result = await res.json();
            if (result.success) {
                showAlert(result.message, true);
                await newTransaction();
            } else {
                showAlert(result.message, false);
            }
        }

        // ── Helpers ───────────────────────────────────────────────────────────
        function showAlert(msg, success) {
            const el = document.getElementById('alertBanner');
            el.className = 'alert-banner ' + (success ? 'alert-success' : 'alert-danger');
            el.textContent = msg;
            el.style.display = 'block';
            setTimeout(() => el.style.display = 'none', 4000);
        }

        function esc(str) {
            if (!str) return '';
            return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        // Close popups on overlay click
        document.getElementById('acctTreePopup').addEventListener('click', function(e) {
            if (e.target === this) closeAcctTreePopup();
        });
        document.getElementById('supplierPopup').addEventListener('click', function(e) {
            if (e.target === this) closeSupplierPopup();
        });
    </script>
    @Html.AntiForgeryToken()
}