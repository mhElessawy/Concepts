@{
    ViewData["Title"] = "Cash Types";
}

<style>
    .ct-def-page {
        background: #fff;
        min-height: calc(100vh - 70px);
        padding: 10px 14px;
        font-size: 0.82rem;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .page-title {
        color: #8b0000;
        font-weight: bold;
        font-size: 1.1rem;
        margin-bottom: 8px;
    }

    /* Form */
    .form-section {
        border: 1px solid #bbb;
        padding: 8px 12px;
        margin-bottom: 8px;
        background: #fff;
    }

    .form-section legend {
        font-size: 0.8rem;
        padding: 0 4px;
        color: #333;
        width: auto;
    }

    .field-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 5px;
    }

    .field-row label {
        min-width: 90px;
        white-space: nowrap;
        font-size: 0.82rem;
    }

    .field-row input[type="text"] {
        border: 1px solid #999;
        padding: 2px 5px;
        font-size: 0.82rem;
        height: 24px;
        width: 200px;
    }

    .def-btn {
        padding: 2px 14px;
        font-size: 0.82rem;
        background: #e0e0e0;
        border: 1px solid #999;
        cursor: pointer;
        height: 24px;
        white-space: nowrap;
    }

    .def-btn:hover { background: #ccc; }
    .def-btn-primary { background: #d4edda; border-color: #28a745; color: #155724; font-weight: bold; }
    .def-btn-primary:hover { background: #c3e6cb; }
    .def-btn-danger { background: #f8d7da; border-color: #dc3545; color: #721c24; }
    .def-btn-danger:hover { background: #f5c6cb; }

    .action-bar {
        display: flex;
        gap: 6px;
        margin-bottom: 8px;
    }

    /* Grid */
    .grid-wrapper {
        border: 1px solid #bbb;
        overflow: auto;
        max-height: 420px;
        background: #fff;
    }

    .def-grid {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.82rem;
    }

    .def-grid thead th {
        background: #ddd;
        border: 1px solid #bbb;
        padding: 4px 8px;
        text-align: left;
        font-weight: normal;
        white-space: nowrap;
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .def-grid tbody td {
        border: 1px solid #ddd;
        padding: 3px 8px;
    }

    .def-grid tbody tr { cursor: pointer; }
    .def-grid tbody tr:hover td { background: #eef; }
    .def-grid tbody tr.selected td { background: #cce5ff; }

    /* Alert */
    .alert-banner {
        padding: 4px 10px;
        font-size: 0.82rem;
        border-radius: 3px;
        margin-bottom: 5px;
        display: none;
    }

    .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .alert-danger  { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
</style>

<div class="ct-def-page">
    <div class="page-title">Cash Types</div>

    <div id="alertBanner" class="alert-banner"></div>

    <!-- Form -->
    <fieldset class="form-section">
        <legend>Cash Type Details</legend>

        <div class="field-row">
            <label>Code</label>
            <input type="text" id="fCode" maxlength="50" />
        </div>
        <div class="field-row">
            <label>Name</label>
            <input type="text" id="fName" maxlength="100" />
        </div>
        <div class="field-row">
            <label>Invoice No.</label>
            <input type="text" id="fInvoiceNo" maxlength="50" placeholder="e.g. CT-001" />
        </div>
        <div class="field-row">
            <label>Active</label>
            <input type="checkbox" id="fActive" checked />
        </div>
    </fieldset>

    <!-- Action bar -->
    <div class="action-bar">
        <button class="def-btn def-btn-primary" onclick="saveRecord()">Save</button>
        <button class="def-btn" onclick="clearForm()">New</button>
        <button class="def-btn def-btn-danger" onclick="deleteRecord()">Delete</button>
    </div>

    <!-- Grid -->
    <div class="grid-wrapper">
        <table class="def-grid">
            <thead>
                <tr>
                    <th style="width:100px;">Code</th>
                    <th style="min-width:180px;">Name</th>
                    <th style="width:130px;">Invoice No.</th>
                    <th style="width:70px;">Active</th>
                </tr>
            </thead>
            <tbody id="gridBody"></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    let currentId = 0;
    let allRows   = [];

    document.addEventListener('DOMContentLoaded', () => loadData());

    async function loadData() {
        const res  = await fetch('/CashTypes/GetAll');
        allRows = await res.json();
        renderGrid();
    }

    function renderGrid() {
        const tbody = document.getElementById('gridBody');
        tbody.innerHTML = '';
        allRows.forEach(r => {
            const tr = document.createElement('tr');
            if (r.id === currentId) tr.classList.add('selected');
            tr.innerHTML = `
                <td>${esc(r.code)}</td>
                <td>${esc(r.name)}</td>
                <td>${esc(r.invoiceNo)}</td>
                <td style="text-align:center;">${r.active ? '✔' : ''}</td>`;
            tr.onclick = () => selectRow(r);
            tbody.appendChild(tr);
        });
    }

    function selectRow(r) {
        currentId = r.id;
        document.getElementById('fCode').value      = r.code;
        document.getElementById('fName').value      = r.name;
        document.getElementById('fInvoiceNo').value = r.invoiceNo;
        document.getElementById('fActive').checked  = r.active;
        renderGrid();
    }

    function clearForm() {
        currentId = 0;
        document.getElementById('fCode').value      = '';
        document.getElementById('fName').value      = '';
        document.getElementById('fInvoiceNo').value = '';
        document.getElementById('fActive').checked  = true;
        renderGrid();
    }

    async function saveRecord() {
        const payload = {
            id:        currentId,
            code:      document.getElementById('fCode').value.trim(),
            name:      document.getElementById('fName').value.trim(),
            invoiceNo: document.getElementById('fInvoiceNo').value.trim(),
            active:    document.getElementById('fActive').checked
        };
        if (!payload.code || !payload.name) {
            showAlert('Code and Name are required.', false); return;
        }
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const res = await fetch('/CashTypes/Save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
            body: JSON.stringify(payload)
        });
        const result = await res.json();
        if (result.success) {
            currentId = result.id;
            showAlert(result.message, true);
            await loadData();
        } else {
            showAlert(result.message, false);
        }
    }

    async function deleteRecord() {
        if (currentId === 0) { showAlert('Select a record first.', false); return; }
        if (!confirm('Delete this cash type?')) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const res = await fetch('/CashTypes/Delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
            body: `id=${currentId}`
        });
        const result = await res.json();
        if (result.success) {
            clearForm();
            showAlert(result.message, true);
            await loadData();
        } else {
            showAlert(result.message, false);
        }
    }

    function showAlert(msg, success) {
        const el = document.getElementById('alertBanner');
        el.className = 'alert-banner ' + (success ? 'alert-success' : 'alert-danger');
        el.textContent = msg;
        el.style.display = 'block';
        setTimeout(() => el.style.display = 'none', 4000);
    }

    function esc(s) {
        if (!s) return '';
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
</script>
@Html.AntiForgeryToken()
}
